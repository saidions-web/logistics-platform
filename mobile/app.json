{
  "expo": {
    "name": "LogiSync Mobile",
    "slug": "LogiSyncMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logoo.png",
    "scheme": "logisyncmobile",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logoo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logoo.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logoo.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://192.168.1.7:8000/api"
    }
  }
}
